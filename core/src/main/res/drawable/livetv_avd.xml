<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="24dp"
            android:height="24dp"
            android:viewportWidth="24"
            android:viewportHeight="24">

            <group
                android:name="antenna_group"
                android:pivotX="12"
                android:pivotY="6">
                <path
                    android:pathData="M12,6L8,2M12,6L16,2"
                    android:strokeWidth="1.5"
                    android:strokeColor="@color/color_icon_bg"
                    android:strokeLineCap="round" />
            </group>

            <path
                android:fillColor="@color/color_icon_bg"
                android:pathData="M21,6H3c-1.1,0 -2,0.9 -2,2v12c0,1.1 0.9,2 2,2h18c1.1,0 2,-0.9 2,-2V8c0,-1.1 -0.9,-2 -2,-2zM21,20H3V8h18v12z" />

            <path
                android:name="live_dot"
                android:fillColor="@color/color_icon_accent"
                android:pathData="M7,12m-1.5,0a1.5,1.5 0,1 1,3 0a1.5,1.5 0,1 1,-3 0" />

            <path
                android:fillColor="@color/color_icon_main"
                android:pathData="M10,12h8v1.5h-8zM10,15h5v1.5h-5z" />
        </vector>
    </aapt:attr>

    <target android:name="antenna_group">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:duration="500"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"
                android:propertyName="rotation"
                android:repeatCount="1"
                android:repeatMode="reverse"
                android:valueFrom="-5"
                android:valueTo="5" />
        </aapt:attr>
    </target>

    <target android:name="live_dot">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:duration="800"
                android:propertyName="fillAlpha"
                android:repeatCount="2"
                android:repeatMode="reverse"
                android:valueFrom="0.0"
                android:valueTo="1.0" />
        </aapt:attr>
    </target>

</animated-vector>