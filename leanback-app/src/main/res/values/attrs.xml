<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="colorPrimary" format="color" />
    <attr name="colorOnPrimary" format="color" />
    <attr name="colorBackground" format="color" />
    <attr name="colorOnBackground" format="color" />
    <attr name="colorSubOnBackground" format="color" />
    <attr name="colorCardBackground" format="color" />
    <attr name="colorSubCardBackground" format="color" />
    <attr name="colorError" format="color" />

    <declare-styleable name="PlaceholderView">
        <attr name="placeholderTint" format="color" />
    </declare-styleable>
    <declare-styleable name="DelayedTextView">
        <attr name="android:textSize" />
        <attr name="android:maxLines" />
        <attr name="color" format="color" />
        <attr name="text" format="string" />
        <attr name="placeholderWidth" format="dimension" />
        <attr name="placeholderHeight" format="dimension" />
    </declare-styleable>
    <declare-styleable name="ButtonView">
        <attr name="android:textSize" />
        <attr name="android:text" />
        <attr name="android:drawable" />
        <attr name="type">
            <enum name="filled" value="0" />
            <enum name="transparent" value="1" />
            <enum name="active" value="2" />
        </attr>
    </declare-styleable>
    <declare-styleable name="UpdateCategoryView">
        <attr name="title" format="string" />
        <attr name="subtitle" format="string" />
        <attr name="status" format="string" />
        <attr name="showUpdateButton" format="boolean" />
        <attr name="showPlaceholder" format="boolean" />
    </declare-styleable>
</resources>