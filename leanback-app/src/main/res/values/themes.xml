<resources>

    <style name="Theme.TripleRockTV.Leanback" parent="Theme.Leanback">
        <item name="playbackProgressPrimaryColor">@color/color_foreground_primary</item>

        <item name="colorBackground">@color/color_background</item>
        <item name="colorSurfacePrimary">@color/color_surface_primary</item>
        <item name="colorSurfaceLow">@color/color_surface_low</item>
        <item name="colorSurfaceMid">@color/color_surface_mid</item>
        <item name="colorSurfaceHigh">@color/color_surface_high</item>
        <item name="colorForegroundPrimary">@color/color_foreground_primary</item>
        <item name="colorForegroundHigh">@color/color_foreground_high</item>
        <item name="colorForegroundMid">@color/color_foreground_mid</item>
        <item name="colorForegroundLow">@color/color_foreground_low</item>
        <item name="colorForegroundFault">@color/color_foreground_fault</item>
        <item name="colorOverlayDark">@color/color_overlay_dark</item>
        <item name="colorOverlayLight">@color/color_overlay_light</item>
    </style>

    <style name="KeyTextStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:padding">5dp</item>
        <item name="android:textColor">@color/card_fg_color_selector2</item>
        <item name="android:background">@color/card_bg_color_selector</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>

    <style name="ButtonStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">15dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textColor">@color/button_fg_color_selector</item>
        <item name="android:drawableTint">@color/button_fg_color_selector</item>
        <item name="android:background">@drawable/button_view_background_transparent</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAlignment">textStart</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:drawablePadding">5dp</item>
    </style>

    <style name="ChipStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:paddingVertical">3dp</item>
        <item name="android:textColor">@color/button_fg_color_selector</item>
        <item name="android:background">@drawable/chip_background</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>
</resources>
