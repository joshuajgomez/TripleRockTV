<resources>

    <style name="Theme.TripleRockTV.Leanback" parent="Theme.Leanback">
        <item name="playbackProgressPrimaryColor">@color/color_primary</item>
        <item name="colorBackground">@color/color_background</item>
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorCardBackground">@color/color_card_background</item>
        <item name="colorCardContent">@color/color_card_content</item>
    </style>

    <style name="KeyTextStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:padding">5dp</item>
        <item name="android:textColor">@color/card_fg_color_selector2</item>
        <item name="android:background">@color/card_bg_color_selector</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>

    <style name="ButtonStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">15dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textColor">@color/button_fg_color_selector</item>
        <item name="android:drawableTint">@color/button_fg_color_selector</item>
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAlignment">textStart</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:drawablePadding">5dp</item>
    </style>
</resources>
