<!-- res/layout/view_stream_card.xml -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/poster_width"
    android:layout_height="@dimen/poster_height"
    android:layout_margin="2dp"
    android:background="?attr/colorBackground"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/focusable_border_fg">

    <ImageView
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_video_file" />

    <ImageView
        android:id="@+id/poster_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        tools:src="@drawable/avatar_movie" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_scrim"
        android:orientation="vertical"
        android:paddingHorizontal="8dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/stream_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="3"
            android:paddingTop="45dp"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="@android:color/white"
            tools:text="Some movie with long name(2025) " />

        <TextView
            android:id="@+id/tv_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_star"
            android:drawablePadding="2dp"
            android:textSize="12sp"
            tools:text="3.5" />
    </LinearLayout>
</FrameLayout>