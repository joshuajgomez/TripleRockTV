<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/popup_width"
    android:layout_height="@dimen/popup_height"
    android:background="@color/color_card_background"
    android:padding="15dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Download not complete"
        android:textColor="?attr/colorCardContent"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:maxLines="7"
        android:text="If you exit this screen, any remaining download will be cancelled"
        android:textColor="@color/color_card_content2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title" />

    <com.joshgm3z.triplerocktv.ui.common.ButtonView
        android:id="@+id/bv_negative"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Continue download"
        android:visibility="gone"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/bv_positive"
        tools:visibility="visible" />

    <com.joshgm3z.triplerocktv.ui.common.ButtonView
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:id="@+id/bv_positive"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Exit screen"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>