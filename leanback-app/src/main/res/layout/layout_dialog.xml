<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/popup_width"
    android:layout_height="@dimen/popup_height"
    android:background="?attr/colorSurfaceLow"
    android:paddingHorizontal="50dp"
    android:paddingVertical="30dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="50dp"
        android:text="Download not complete"
        android:textColor="?attr/colorForegroundHigh"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/bv_positive"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:maxLines="7"
        android:text="If you exit this screen, any remaining download will be cancelled"
        android:textColor="?attr/colorForegroundMid"
        app:layout_constraintEnd_toEndOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="@+id/tv_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_title" />

    <com.joshgm3z.triplerocktv.ui.common.ButtonView
        android:id="@+id/bv_positive"
        android:layout_width="230dp"
        android:layout_height="wrap_content"
        android:text="Proceed"
        android:textAlignment="viewStart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.joshgm3z.triplerocktv.ui.common.ButtonView
        android:id="@+id/bv_negative"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="Dismiss"
        android:textAlignment="viewStart"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@+id/bv_positive"
        app:layout_constraintStart_toStartOf="@+id/bv_positive"
        app:layout_constraintTop_toBottomOf="@+id/bv_positive"
        app:type="filled"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>