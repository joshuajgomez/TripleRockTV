<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:width="24dp"
            android:height="24dp"
            android:viewportWidth="24"
            android:viewportHeight="24">

            <path
                android:fillColor="@color/color_icon_main"
                android:pathData="M2,8 h20 v11 c0,1.1 -0.9,2 -2,2 H4 c-1.1,0 -2,-0.9 -2,-2 V8 Z" />

            <group
                android:name="clapper_top"
                android:pivotX="2"
                android:pivotY="8">
                <path
                    android:fillColor="@color/color_icon_bg"
                    android:pathData="M2,4 h20 v4 H2 V4 Z" />
                <path
                    android:fillColor="@color/color_icon_accent"
                    android:pathData="M6,4 l3,4 h3 l-3,-4 H6 Z M13,4 l3,4 h3 l-3,-4 H13 Z" />
            </group>
        </vector>
    </aapt:attr>
    <target android:name="clapper_top">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:duration="400"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator"
                android:propertyName="rotation"
                android:repeatCount="1"
                android:repeatMode="reverse"
                android:valueFrom="-11"
                android:valueTo="0"
                android:valueType="floatType" />
        </aapt:attr>
    </target>

</animated-vector>
