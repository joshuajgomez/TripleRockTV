<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State when the view is focused -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <stroke android:width="@dimen/stroke_width" android:color="?attr/colorForegroundPrimary" />
            <corners android:radius="5dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <stroke android:width="@dimen/stroke_width" android:color="?attr/colorForegroundPrimary" />
            <corners android:radius="5dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="@dimen/stroke_width" android:color="?attr/colorForegroundLow" />
            <corners android:radius="5dp" />
        </shape>
    </item>
</selector>