<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark Transparent Circle Background -->
    <item>
        <shape android:shape="oval">
            <solid android:color="?attr/colorOverlayDark" />
            <size
                android:width="48dp"
                android:height="48dp" />
        </shape>
    </item>

    <!-- Play Icon (Triangle) -->
    <item
        android:gravity="center"
        android:left="0dp"> <!-- Offset slightly to the right to visually center the triangle -->
        <vector
            android:width="44dp"
            android:height="44dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <path
                android:fillColor="?attr/colorForegroundPrimary"
                android:pathData="M8,5v14l11,-7z" />
        </vector>
    </item>
</layer-list>
